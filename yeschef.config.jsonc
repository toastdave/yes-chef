{
  "$schema": "https://yeschef.ai/config.json",
  "project": {
    "name": "yes-chef",
    "baseBranch": "main"
  },
  "validations": {
    "typecheck": "bun run typecheck"
  },
  "packs": {
    "browser": {
      "enabled": false
    }
  },
  "ui": {
    "theme": "yes-chef",
    "streamMode": "events"
  }
}
