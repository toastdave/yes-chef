{
  "$schema": "https://yeschef.ai/config.json",
  "project": {
    "name": "yes-chef",
    "baseBranch": "main"
  },
  // Add project-specific custom agents here. They merge over global config.
  // Example:
  // "agents": {
  //   "custom-cook": {
  //     "role": "line-cook",
  //     "backend": "auto",
  //     "model": "gpt-5-codex",
  //     "mode": "delegate",
  //     "backendAgent": "build",
  //     "prompt": "custom-line-cook"
  //   }
  // },
  // "roleDefaults": {
  //   "line-cook": "custom-cook"
  // },
  // "skills": {
  //   "api-debugging": {
  //     "summary": "Trace API failures systematically",
  //     "requiredTools": ["bash", "read"]
  //   }
  // },
  // "packs": {
  //   "browser": {
  //     "enabled": true,
  //     "skills": ["browser-qa"],
  //     "env": { "YESCHEF_BROWSER_PACK": "1" },
  //     "tools": { "browser": true }
  //   }
  // },
  // "routing": {
  //   "roleSkills": {
  //     "line-cook": ["verification-before-completion"]
  //   },
  //   "kindSkills": {
  //     "repair": ["systematic-debugging"]
  //   },
  //   "uiPackRoles": ["expo", "critic"]
  // },
  "policies": {
    "worktrees": {
      "mode": "auto",
      "cleanup": "delete",
      "keepFailed": true
    },
    "completion": {
      "requireValidations": true,
      "conventionalCommits": false
    },
    "riskyPaths": []
  },
  "validations": {
    "typecheck": "bun run typecheck"
  },
  "packs": {
    "browser": {
      "enabled": false
    }
  },
  "ui": {
    "theme": "yes-chef",
    "streamMode": "events"
  }
}
