{
  "$schema": "https://yeschef.ai/config.json",
  "project": {
    "name": "yes-chef",
    "baseBranch": "main"
  },
  // Add project-specific custom agents here. They merge over global config.
  // Example:
  // "agents": {
  //   "custom-cook": {
  //     "role": "line-cook",
  //     "backend": "auto",
  //     "model": "gpt-5-codex",
  //     "mode": "delegate",
  //     "backendAgent": "build",
  //     "prompt": "custom-line-cook"
  //   }
  // },
  // "roleDefaults": {
  //   "line-cook": "custom-cook"
  // },
  "policies": {
    "worktrees": {
      "mode": "auto",
      "cleanup": "delete",
      "keepFailed": true
    },
    "completion": {
      "requireValidations": true,
      "conventionalCommits": false
    },
    "riskyPaths": []
  },
  "validations": {
    "typecheck": "bun run typecheck"
  },
  "packs": {
    "browser": {
      "enabled": false
    }
  },
  "ui": {
    "theme": "yes-chef",
    "streamMode": "events"
  }
}
